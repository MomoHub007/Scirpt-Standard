	function RetryManager.shouldRetry(op, attempts)
		local limits = { SCAN_MONSTERS = 3, CHARACTER_MISSING = 5, TELEPORT_FAILED = 2, TELEPORT_COOLDOWN = 5, WAIT_UNTIL_DEAD_TIMEOUT = 2 }
		return attempts <= (limits[op] or 2)
	end

	function RetryManager.getRetryDelay(attempts)
		return math.min(250 * (2 ^ (math.max(1, attempts) - 1)), 2500)
	end

	function ErrorHandler.handle(errType, context, retryCallback)
		if errType == "COROUTINE_CRASH" or errType == "CRITICAL_PERFORMANCE" then return "STOP" end
		local op = context and context.operation or errType
		local attempts = (Shared.State.retryAttempts[op] or 0) + 1
		Shared.State.retryAttempts[op] = attempts
		if RetryManager.shouldRetry(op, attempts) then
			if retryCallback then task.delay(RetryManager.getRetryDelay(attempts)/1000, function() pcall(retryCallback) end) end
			return "RETRY"
		end
		return "SKIP"
	end

	function PerformanceMonitor.init()
		if Shared.Connections.system.PerfConn then return end
		local conn = game:GetService("RunService").Heartbeat:Connect(function(dt)
			local perf = Shared.State.performance
			perf.frameCounter += 1
			perf.frameAccumulator += dt
			if perf.frameAccumulator >= 1 then
				perf.currentFPS = perf.frameCounter / perf.frameAccumulator
				perf.frameCounter, perf.frameAccumulator, perf.lastSampleAt = 0, 0, now()
			end
		end)
		Shared.Connections.system.PerfConn = conn
		table.insert(Shared.Connections.system, conn)
	end

	function MonsterStateTracker.isAlive(monster)
		if not (monster and monster.Parent) then return false end
		local cache = Shared.Caches.monsterState[monster]
		if cache and (now() - cache.timestamp) <= Shared.Config.MonsterStateCacheLifetime then return cache.alive end
		local attackable = monster:GetAttribute("Attackable")
		local turnable = monster:GetAttribute("Turnable")
		local alive = (attackable == true and turnable == true)
		Shared.Caches.monsterState[monster] = { alive = alive, timestamp = now() }
		return alive
	end

	function MonsterStateTracker.waitUntilDead(monster, timeout)
		local deadline = now() + (timeout or Shared.Config.TargetDeadTimeout)
		while now() < deadline do
			if not MonsterStateTracker.isAlive(monster) then return true end
			task.wait(Shared.Config.WaitDeadPollInterval)
		end
		return not MonsterStateTracker.isAlive(monster)
	end

	function MonsterDiscoveryService._markDirty() Shared.State.lastMonsterRefresh = 0 end

	function MonsterDiscoveryService.refreshMonsterList()
		local ok, err = pcall(function()
			local monstersByName, uniqueNames, flatMonsters, seenNames = {}, {}, {}, {}
			for _, world in ipairs(workspace:GetChildren()) do
				if matchesWorldName(world.Name) then
					local ef = world:FindFirstChild("Enemy")
					if ef then
						for _, obj in ipairs(ef:GetChildren()) do
							if obj:IsA("Model") then
								local name = obj.Name
								if not monstersByName[name] then monstersByName[name] = {} end
								table.insert(monstersByName[name], obj)
								table.insert(flatMonsters, obj)
								if not seenNames[name] then seenNames[name] = true; table.insert(uniqueNames, name) end
							end
						end
					end
				end
			end
			table.sort(uniqueNames)
			Shared.Caches.allMonsters, Shared.Caches.uniqueNames, Shared.Caches.flatMonsters = monstersByName, uniqueNames, flatMonsters
			Shared.State.lastMonsterRefresh = now()
		end)
		return ok
	end

	function MonsterDiscoveryService.getNearestMonster()
		local cur = now()
		if Shared.State.nearestCache and Shared.State.nearestCache.Parent and cur - Shared.State.lastNearCacheAt <= Shared.Config.NearCacheLifetime then
			if MonsterStateTracker.isAlive(Shared.State.nearestCache) then return Shared.State.nearestCache end
		end
		local hrp = getCharacterRoot()
		if not hrp then return nil end
		local myPos, nearest, bestDist = hrp.Position, nil, math.huge
		for _, monster in ipairs(Shared.Caches.flatMonsters) do
			if monster.Parent and MonsterStateTracker.isAlive(monster) then
				local mRoot = getMonsterRoot(monster)
				if mRoot then
					local d2 = getDistanceSquared(myPos, mRoot.Position)
					if d2 < bestDist then bestDist, nearest = d2, monster end
				end
			end
		end
		Shared.State.nearestCache, Shared.State.lastNearCacheAt = nearest, cur
		return nearest
	end

	function FarmCoordinator.stopFarming()
		Shared.State.isFarming, Shared.State.isPaused, Shared.State.currentTarget = false, false, nil
		setStatus("Stopped", true)
	end

	function FarmCoordinator.startFarming()
		if Shared.State.farmMode == "SELECT" and #Shared.State.selectedMonsterNames == 0 then
			MoMoNotify({Title = "Auto Farm", Desc = "Please select monsters first", Time = 3})
			return false
		end
		Shared.State.isFarming, Shared.State.isPaused, Shared.State.nextLoopAt = true, false, 0
		setStatus("Running", true)
		return true
	end

	function FarmCoordinator._tick()
		if not Shared.State.isFarming then return end
		local cur = now()
		if Shared.State.isPaused and cur < Shared.State.pauseUntil then return end
		if cur < Shared.State.nextLoopAt then return end

		local hrp = getCharacterRoot()
		if not hrp then return end

		if cur - Shared.State.lastMonsterRefresh >= Shared.Config.MonsterRefreshInterval then
			MonsterDiscoveryService.refreshMonsterList()
			UIManager.refreshMonsterDropdown()
		end

		local target
		if Shared.State.farmMode == "SELECT" then
			local names = Shared.State.selectedMonsterNames
			if #names > 0 then
				if Shared.State.currentSelectedIndex > #names then Shared.State.currentSelectedIndex = 1 end
				local name = names[Shared.State.currentSelectedIndex]
				local instances = Shared.Caches.allMonsters[name] or {}
				for _, m in ipairs(instances) do if m.Parent and MonsterStateTracker.isAlive(m) then target = m; break end end
				if not target then Shared.State.currentSelectedIndex = (Shared.State.currentSelectedIndex % #names) + 1 end
			end
		else
			target = MonsterDiscoveryService.getNearestMonster()
		end

		Shared.State.currentTarget = target
		if not target then
			setStatus("Waiting for target")
			Shared.State.nextLoopAt = cur + Shared.State.scanInterval
			return
		end

		-- Teleport and Kill (Normal Mode)
		local mRoot = getMonsterRoot(target)
		if mRoot and (nowMs() - Shared.State.lastPlacementAt >= Shared.Config.PlacementCooldownMs) then
			hrp.CFrame = mRoot.CFrame * CFrame.new(Shared.Config.TeleportOffset)
			Shared.State.lastPlacementAt, Shared.State.totalTeleports = nowMs(), Shared.State.totalTeleports + 1
			setStatus("Fighting " .. target.Name)
			if MonsterStateTracker.waitUntilDead(target) then
				Shared.State.killedCount += 1
				if #Shared.State.selectedMonsterNames > 0 then
					Shared.State.currentSelectedIndex = (Shared.State.currentSelectedIndex % #Shared.State.selectedMonsterNames) + 1
				end
			end
		end
		Shared.State.nextLoopAt = now() + 0.1
	end

	--==================================================
	-- UI Integration
	--==================================================

	function UIManager.updateStatusText(text)
		local btn = Shared.UI.Components.StatusDisplay
		if btn and btn.SetName then btn:SetName("Status: " .. text) end
	end

	function UIManager.refreshMonsterDropdown()
		local dd = Shared.UI.Components.MonsterDropdown
		if not dd then return end
		local options = Shared.Caches.uniqueNames
		if #options == 0 then options = {"None"} end
		pcall(function()
			dd:ClearOptions()
			dd:InsertOptions(options)
		end)
	end

	function UIManager.init()
		local farmTab = Shared.UI.TabGroup:Tab({ Name = "Auto Farm", Image = "rbxassetid://6031092050" })
		local farmSec = farmTab:Section({ Side = "Left" })
		Shared.UI.Components.FarmSection = farmSec

		farmSec:Header({ Name = "Monster Selection" })
		Shared.UI.Components.MonsterDropdown = farmSec:Dropdown({
			Name = "Select Monster",
			Options = Shared.Caches.uniqueNames,
			Default = {},
			Search = true,
			Multi = true,
			Callback = function(val)
				local selected = {}
				local opts = Shared.Caches.uniqueNames
				if type(val) == "table" then
					for _, v in ipairs(val) do
						local name = (type(v) == "number") and opts[v] or v
						if name and name ~= "None" then table.insert(selected, name) end
					end
				elseif type(val) == "string" and val ~= "None" then table.insert(selected, val) end
				Shared.State.selectedMonsterNames = selected
				MoMoNotify({Title = "Selected", Desc = (#selected > 0 and table.concat(selected, ", ") or "None"), Time = 2})
			end
		})

		farmSec:Dropdown({
			Name = "Farm Mode",
			Options = {"SELECT", "NEAR"},
			Default = "SELECT",
			Callback = function(v) Shared.State.farmMode = v; setStatus("Mode: " .. v, true) end
		})

		farmSec:Button({ Name = "Refresh List", Callback = function() MonsterDiscoveryService.refreshMonsterList(); UIManager.refreshMonsterDropdown() end })

		farmSec:Header({ Name = "Farm Control" })

		Shared.UI.Components.FarmToggle = farmSec:Toggle({
			Name = "Auto Farm",
			Default = false,
			Callback = function(v) if v then if not FarmCoordinator.startFarming() then task.delay(0.1, function() pcall(function() Shared.UI.Components.FarmToggle:SetValue(false) end) end) end else FarmCoordinator.stopFarming() end end
		})

		farmSec:Button({ Name = "Stop Farm", Callback = function() FarmCoordinator.stopFarming(); pcall(function() Shared.UI.Components.FarmToggle:SetValue(false) end) end })

		local statBtn = farmSec:Button({ Name = "Show Stats", Callback = function() MoMoNotify({Title="Stats", Desc=string.format("Kills: %d | TPs: %d", Shared.State.killedCount, Shared.State.totalTeleports), Time=4}) end })

		Shared.UI.Components.StatusDisplay = farmSec:Button({ Name = "Status: Idle", Callback = function() MoMoNotify({Title="Status", Desc=Shared.State.currentStatus, Time=2}) end })
	end


	function AutoFarmSystem.init()
		PerformanceMonitor.init()
		MonsterDiscoveryService.refreshMonsterList()
		UIManager.init()
		task.spawn(FarmCoordinator._tick_loop)
	end

	function FarmCoordinator._tick_loop()
		Shared.State.initialized = true
		while Shared.State.initialized do
			pcall(FarmCoordinator._tick)
			task.wait(Shared.Config.LoopIdleInterval)
		end
	end

	AutoFarmSystem.init()
end


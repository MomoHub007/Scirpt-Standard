			isPaused = false,
			pauseUntil = 0,
			stopRequested = false,
			backgroundLoopRunning = false,
			maintenanceLoopRunning = false,
			currentTarget = nil,
			currentStatus = "Idle",
			lastStatusUpdate = 0,
			killedCount = 0,
			totalTeleports = 0,
			errors = 0,
			scanInterval = 2.0,
			lastMonsterRefresh = 0,
			lastPerformanceCheck = 0,
			lastPlacementAt = 0,
			lastNearCacheAt = 0,
			nextLoopAt = 0,
			currentSelectedIndex = 1,
			farmMode = "SELECT",
			selectedMonsterNames = {},
			nearestCache = nil,
			retryAttempts = {},
			performance = {
				currentFPS = 60,
				frameCounter = 0,
				frameAccumulator = 0,
				lastSampleAt = os.clock(),
			},
		},
		Caches = {
			allMonsters = {},
			uniqueNames = {},
			flatMonsters = {},
			monsterState = setmetatable({}, { __mode = "k" }),
			deathBindings = setmetatable({}, { __mode = "k" }),
		},
		Connections = {
			workspace = {},
			enemyFolders = {},
			system = {},
		},

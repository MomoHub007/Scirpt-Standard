		},
	}

	local MonsterDiscoveryService = {}
	local MonsterStateTracker = {}
	local FarmModeSelector = {}
	local TeleportationService = {}
	local FarmCoordinator = {}
	local UIManager = {}
	local ErrorHandler = {}
	local RetryManager = {}
	local PerformanceMonitor = {}

	local function log(level, message, ...)
		if level == "DEBUG" and not Shared.Config.Debug then return end
		local prefix = string.format("[AutoFarmSystem][%s] %s", level, message)
		if select("#", ...) > 0 then warn(prefix, ...) else warn(prefix) end
	end

	local function safeDisconnect(connection)
		if connection and typeof(connection) == "RBXScriptConnection" then pcall(function() connection:Disconnect() end) end
	end

	local function clearConnectionList(list)
		if not list then return end
		for i = 1, #list do safeDisconnect(list[i]) end
		table.clear(list)
	end

	local function shallowCopyArray(arr)
		local newArr = {}
		if type(arr) ~= "table" then return newArr end
		for i = 1, #arr do newArr[i] = arr[i] end
		return newArr
	end

	local function now() return os.clock() end
	local function nowMs() return math.floor(os.clock() * 1000) end

	local function normalizeMode(mode)
		if type(mode) ~= "string" then return "SELECT" end
		mode = string.upper(mode)
		return (mode == "NEAR") and "NEAR" or "SELECT"
	end

	local function matchesWorldName(name) return string.match(name, "^World%d+$") ~= nil end
	local function getCharacterRoot()
		local char = LP.Character
		if not (char and char.Parent) then return nil end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		return (hrp and hrp:IsA("BasePart")) and hrp or nil
	end

	local function getMonsterRoot(monster)
		if not (monster and monster.Parent) then return nil end
		local hrp = monster:FindFirstChild("HumanoidRootPart") or monster.PrimaryPart or monster:FindFirstChildWhichIsA("BasePart")
		return (hrp and hrp:IsA("BasePart")) and hrp or nil
	end

	local function getDistanceSquared(a, b)
		local delta = a - b
		return delta.X * delta.X + delta.Y * delta.Y + delta.Z * delta.Z
	end

	local function setStatus(text, notify)
		Shared.State.currentStatus = text
		UIManager.updateStatusText(text)
		if notify then
			local cur = now()
			if cur - Shared.State.lastStatusUpdate >= Shared.Config.StatusNotifyThrottle then
				Shared.State.lastStatusUpdate = cur
				MoMoNotify({Title = "Auto Farm", Desc = text, Time = 2})
			end
		end
	end


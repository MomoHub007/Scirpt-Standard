	local PerformanceMonitor = {}

	local STAR_OPTIONS = { "Star1", "Star2", "Star3", "Star4" }
	local RANDOM = Random.new()

	local function log(level, message, ...)
		if level == "DEBUG" and not Shared.Config.Debug then return end
		local prefix = string.format("[AutoEggSystem][%s] %s", tostring(level), tostring(message))
		if select("#", ...) > 0 then warn(prefix, ...) else warn(prefix) end
	end

	local function notify(title, desc, timeValue)
		pcall(function()
			if type(MoMoNotify) == "function" then
				MoMoNotify({ Title = title or "Auto Egg", Desc = desc or "", Time = timeValue or 3 })
			end
		end)
	end

	local function clamp(value, minValue, maxValue)
		value = tonumber(value) or minValue
		return math.min(math.max(value, minValue), maxValue)
	end

	local function starIsValid(star)
		for i = 1, #STAR_OPTIONS do if STAR_OPTIONS[i] == star then return true end end
		return false
	end

	local function safeSetComponentText(component, text)
		if not component then return false end
		local methods = { "SetName", "Update", "SetText", "SetTitle" }
		for i = 1, #methods do
			if type(component[methods[i]]) == "function" then
				if pcall(function() component[methods[i]](component, text) end) then return true end
			end
		end
		return pcall(function() component.Name = text end)
	end

	local function safeSetToggle(toggle, value)
		if not toggle then return false end
		local methods = { "SetValue", "Update", "SetActive" }
		for i = 1, #methods do
			if type(toggle[methods[i]]) == "function" then
				if pcall(function() toggle[methods[i]](toggle, value) end) then return true end
			end
		end
		return pcall(function() toggle.Value = value end)
	end

	local function setStatus(text, shouldNotify)
		Shared.State.currentStatus = tostring(text or "Unknown")
		if Shared.UI.Components.StatusButton then safeSetComponentText(Shared.UI.Components.StatusButton, "Status: " .. text) end
		if shouldNotify then notify("Auto Egg", Shared.State.currentStatus, 2) end
	end

	function PerformanceMonitor.init()
		local conn = RunService.Heartbeat:Connect(function(dt)
			Shared.Performance.lastHeartbeatAt = os.clock()
			Shared.Performance.avgDelta = (Shared.Performance.avgDelta * 0.9) + (dt * 0.1)
		end)
		table.insert(Shared.State.connections, conn)
	end

	function PerformanceMonitor.getCurrentCallRate()
		local nowTime = os.clock()
		local history = Shared.RateLimiter.callHistory
		while #history > 0 and (nowTime - history[1]) > 1 do table.remove(history, 1) end
		return #history
	end

	function PerformanceMonitor.suggestInterval()
		local currentRate = PerformanceMonitor.getCurrentCallRate()
		local target = Shared.EggConfig.intervalSeconds
		if currentRate > Shared.Config.WarnCallsPerSecond then target = math.max(target, 0.12) end
		if Shared.State.lastResponseTime > 0.5 then target = math.max(target, 0.2) end
		return clamp(target, Shared.EggConfig.minInterval, Shared.EggConfig.maxInterval)
	end

	function RateLimiter.canCall()
		if Shared.State.remoteBusy then return false end
		local required = math.max(Shared.RateLimiter.actualInterval, Shared.Config.PlacementCooldownSeconds, Shared.EggConfig.intervalSeconds)
		return (os.clock() - Shared.RateLimiter.lastCallTimestamp) >= required
	end

	function RateLimiter.recordCall()
		local nowTime = os.clock()
		Shared.RateLimiter.lastCallTimestamp = nowTime
		table.insert(Shared.RateLimiter.callHistory, nowTime)
	end

	function EggConfigManager.setStar(s) if starIsValid(s) then Shared.EggConfig.selectedStar = s; return true end return false end
	function EggConfigManager.setEggsPerHatch(a) Shared.EggConfig.eggsPerHatch = clamp(math.floor(a + 0.5), 1, 10); return true end
	function EggConfigManager.setInterval(s) Shared.EggConfig.intervalSeconds = clamp(s, Shared.EggConfig.minInterval, Shared.EggConfig.maxInterval); return true end

	function EggRemoteInvoker.getRemote()
		local cached = Shared.Remote.cached
		if cached and typeof(cached) == "Instance" and cached.Parent then return cached end
		local ok, res = pcall(function() return ReplicatedStorage:WaitForChild("Remotes", 5):WaitForChild("Eggs", 5):WaitForChild("Hatch", 5) end)
		if ok and res then Shared.Remote.cached = res; return res end
		return nil
	end

	function EggRemoteInvoker.invokeHatch(star, quantity)
		local start = os.clock()
		local remote = EggRemoteInvoker.getRemote()
		if not remote then return false, nil, "Remote not found" end
		Shared.State.remoteBusy = true
		local s, r = pcall(function() return remote:InvokeServer(star, quantity) end)
		Shared.State.remoteBusy = false
		Shared.State.lastResponseTime = os.clock() - start
		return s, r
	end

	function UIManager.init(parentTabGroup)
		local eggTab = parentTabGroup:Tab({ Name = "Auto Egg", Image = "rbxassetid://6031075931" })
		local left = eggTab:Section({ Side = "Left" })
		local right = eggTab:Section({ Side = "Right" })

		left:Dropdown({
			Name = "Select Star",
			Options = STAR_OPTIONS,
			Default = Shared.EggConfig.selectedStar,
			Callback = function(v) EggConfigManager.setStar(type(v) == "table" and v[1] or v) end
		})
		left:Slider({
			Name = "Eggs Per Hatch",
			Default = Shared.EggConfig.eggsPerHatch,
			Minimum = 1, Maximum = 10,
			Callback = function(v) EggConfigManager.setEggsPerHatch(v) end
		})
		Shared.UI.Components.AutoToggle = left:Toggle({
			Name = "Auto Open Egg",
			Default = false,
			Callback = function(v) if v then EggLoopController.startLoop() else EggLoopController.stopLoop() end end
		})
		Shared.UI.Components.StatusButton = right:Button({ Name = "Status: Stopped", Callback = function() notify("Status", Shared.State.currentStatus) end })
		
		task.spawn(function()
			while true do
				if Shared.UI.Components.StatusButton then safeSetComponentText(Shared.UI.Components.StatusButton, "Status: " .. Shared.State.currentStatus .. " | Eggs: " .. Shared.State.totalEggsOpened) end
				task.wait(1)
			end
		end)
	end

	function EggLoopController.startLoop() Shared.State.isRunning = true; setStatus("Running", true) end
	function EggLoopController.stopLoop() Shared.State.isRunning = false; setStatus("Stopped", true) end

	function EggLoopController._mainLoop()
		task.spawn(function()
			while true do
				if Shared.State.isRunning and RateLimiter.canCall() then
					local s, r = EggRemoteInvoker.invokeHatch(Shared.EggConfig.selectedStar, Shared.EggConfig.eggsPerHatch)
					if s then
						Shared.State.totalCalls += 1
						Shared.State.totalEggsOpened += Shared.EggConfig.eggsPerHatch
						RateLimiter.recordCall()
					end
				end
				task.wait(Shared.Config.LoopIdleWait)
			end
		end)
	end

	function AutoEggSystem.init(parentTabGroup)
		PerformanceMonitor.init()
		UIManager.init(parentTabGroup)
		EggLoopController._mainLoop()
		Shared.State.initialized = true
	end

	task.spawn(function() pcall(function() AutoEggSystem.init(tabGroups.Main) end) end)
end


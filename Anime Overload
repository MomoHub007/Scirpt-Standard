    -- 🌟 ศูนย์รวมระบบอัปเดตรายชื่อ (สมองกลสแกนคำสั่งลับ)
    local function ForceUpdateDropdown(newFileName)
        local currentList = getMacroFiles()
        
        if newFileName then
            local found = false
            for _, v in ipairs(currentList) do
                if v == newFileName then found = true break end
            end
            if not found then
                if currentList[1] == "None" then currentList = {newFileName} else table.insert(currentList, newFileName) end
            end
        end

        if macroDropdown then
            local success = false
            local availableMethods = ""
            
            for funcName, func in pairs(macroDropdown) do
                if type(func) == "function" then
                    availableMethods = availableMethods .. funcName .. ", "
                    local lowerName = string.lower(funcName)
                    if lowerName:find("option") or lowerName:find("refresh") or lowerName:find("updatelist") or lowerName:find("setlist") or lowerName:find("reload") then
                        local ok = pcall(function() func(macroDropdown, currentList) end)
                        if ok then success = true end
                    end
                end
            end
            
            if newFileName then
                _G.SelectedMacro = newFileName
                pcall(function() macroDropdown:UpdateSelection(newFileName) end)
            end

            if not success then
                warn("❌ [MacLib Scanner] หาคำสั่งอัปเดตรายชื่อของ MacLib ไม่เจอ!")
            end
        end
    end


        return attackTowersBySlot, farmTowers, unknownTowers, placedFolder
    end



    local function tryPlaceFarm(sync, farmCard, placedFolder, farmLimit)
        if not sync or not farmCard then return false end

        local placedFarm = placedTracking[farmCard.Slot] or 0
        if placedFarm >= farmLimit then return false end
        if not canAttemptFarm() then return false end
        if getRealMoney() < farmCard.Cost then return false end

        local success = false

        for _ = 1, 6 do
            -- 🌟 แก้ตรงนี้: เปลี่ยนจาก findFarmSpot() เป็น findSpot() เพื่อให้วางเหมือนตัวตีปกติ
            local spot = findSpot() 
            
            if spot and not isNearFailedSpot(spot.Position, 5) then
                local countBefore = placedFolder and #placedFolder:GetChildren() or 0
                local ok = pcall(function()
                    sync.clientTowerPlacement.call(farmCard.UUID, spot)
                end)

                if ok then
                    task.wait(0.9)
                    local countAfter = placedFolder and #placedFolder:GetChildren() or 0
                    if countAfter > countBefore then
                        placedTracking[farmCard.Slot] = (placedTracking[farmCard.Slot] or 0) + 1
                        -- 🌟 สั่งให้จดจำพิกัด พร้อมผูกกับ Slot ของตัวฟาร์ม
                        table.insert(placedUnitMemory, {pos = spot.Position, slot = farmCard.Slot})
                        success = true

                        break
                    else
                        markFailedSpot(spot.Position)
                    end
                else
                    markFailedSpot(spot.Position)
                end
            end
        end

        markFarmAttempt(success)
        return success
    end

    local function tryPlacePriorityAttack(sync, deck, farmSlot, placedFolder)
        if not sync or #deck == 0 then return false end
        if not canAttemptPlacement() then return false end

        local money = getRealMoney()
        local priorityCards = getOrderedPriorityCards(deck, farmSlot)
        local success = false

        for _, card in ipairs(priorityCards) do
            local limit = MoMoConfig.UnitLimits[card.Slot] or 0
            local placed = placedTracking[card.Slot] or 0

            if placed < limit and money >= card.Cost then
                for _ = 1, 6 do
                    -- 🌟 เรียกใช้ findSpot() ตรงๆ ไปเลย ไม่ต้องคำนวณซ้ำซ้อน
                    local spot = findSpot() 
                    if spot and spot.Position and not isNearFailedSpot(spot.Position, 4) then
                        local countBefore = placedFolder and #placedFolder:GetChildren() or 0
                        local ok = pcall(function()
                            sync.clientTowerPlacement.call(card.UUID, spot)
                        end)

                        if ok then
                            task.wait(0.9)
                            local countAfter = placedFolder and #placedFolder:GetChildren() or 0
                            if countAfter > countBefore then
                                placedTracking[card.Slot] = (placedTracking[card.Slot] or 0) + 1
                                -- 🌟 สั่งให้จดจำพิกัด พร้อมผูกกับ Slot ของตัวตี
                                table.insert(placedUnitMemory, {pos = spot.Position, slot = card.Slot})
                                success = true

                                break
                            else
                                markFailedSpot(spot.Position)
                            end
                        else
                            markFailedSpot(spot.Position)
                        end
                    end
                end
            end

            if success then
                break
            end
        end

        markPlacementAttempt(success)
        return success
    end


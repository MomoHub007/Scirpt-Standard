    local function getDeckCardBySlot(deck, slot)
        for _, card in ipairs(deck) do
            if card.Slot == slot then
                return card
            end
        end
        return nil
    end

    local function getOrderedPriorityCards(deck, farmSlot)
        local result = {}

        for _, slotNum in ipairs(MoMoConfig.UnitPriority) do
            if slotNum ~= farmSlot then
                local card = getDeckCardBySlot(deck, slotNum)
                if card then
                    table.insert(result, card)
                end
            end
        end

        for _, card in ipairs(deck) do
            local exists = false
            for _, picked in ipairs(result) do
                if picked.Slot == card.Slot then
                    exists = true
                    break
                end
            end
            if not exists and card.Slot ~= farmSlot then
                table.insert(result, card)
            end
        end

        return result
    end

    local function classifyPlacedTowers()
        local attackTowersBySlot = { [1]={}, [2]={}, [3]={}, [4]={}, [5]={}, [6]={} }

    -- [PATCH REPLACEMENT] TEXT-BASED EVENT CARD PARSER
    local function superSanitize(str)
        if type(str) ~= "string" then
            return ""
        end
        return str:gsub("[%s%p%c]+", ""):lower()
    end

    local function buildSanitizedKnownMap()
        local map = {}
        for _, knownName in ipairs(knownEventCards) do
            map[superSanitize(knownName)] = knownName
        end
        return map
    end

    local function getTextLabelScore(label)
        local score = 0

        pcall(function()
            score = score + ((label.TextSize or 0) * 10)
        end)

        pcall(function()
            score = score + math.clamp(label.AbsoluteSize.Y or 0, 0, 300)
        end)

        pcall(function()
            local y = (label.AbsolutePosition and label.AbsolutePosition.Y) or 99999
            score = score + math.clamp(2000 - y, 0, 2000)
        end)

        pcall(function()
            local fontName = tostring(label.Font)
            if fontName:lower():find("bold") then
                score = score + 150
            end
        end)

        pcall(function()
            local text = tostring(label.Text or "")
            if #text > 0 and #text <= 32 then
                score = score + 75
            end
        end)

        return score
    end

    local function extractKnownCardNameFromInstance(inst)
        if not inst then
            return nil
        end

        local sanitizedKnownMap = buildSanitizedKnownMap()
        local candidates = {}

        local function tryAddLabel(label)
            if not label or not label:IsA("TextLabel") then
                return
            end

            if not isGuiActuallyVisible(label) then
                return
            end

            local rawText = tostring(label.Text or "")
            local cleanText = superSanitize(rawText)
            if cleanText == "" then
                return
            end

            local exactMatch = sanitizedKnownMap[cleanText]
            if exactMatch then
                table.insert(candidates, {
                    Name = exactMatch,
                    Score = 100000 + getTextLabelScore(label),
                    Label = label,
                })
                return
            end

            for sanitizedKnown, originalKnown in pairs(sanitizedKnownMap) do
                if cleanText:find(sanitizedKnown, 1, true) or sanitizedKnown:find(cleanText, 1, true) then
                    table.insert(candidates, {
                        Name = originalKnown,
                        Score = 50000 + getTextLabelScore(label),
                        Label = label,
                    })
                    return
                end
            end
        end

        pcall(function()
            if inst:IsA("TextLabel") then
                tryAddLabel(inst)
            end

            for _, child in ipairs(inst:GetDescendants()) do
                if child:IsA("TextLabel") then
                    tryAddLabel(child)
                end
            end
        end)

        if #candidates == 0 then
            return nil
        end

        table.sort(candidates, function(a, b)
            return a.Score > b.Score
        end)

        return candidates[1].Name
    end

    local function getClickableCardRoot(inst)
        if not inst then
            return nil
        end

        local current = inst
        local bestFallback = nil

        while current and current.Parent and current.Name ~= "PlayerGui" do
            if isGuiActuallyVisible(current) then
                if current:IsA("GuiButton") then
                    local absY = 0
                    local absX = 0

                    pcall(function()
                        absY = current.AbsoluteSize.Y
                        absX = current.AbsoluteSize.X
                    end)

                    if absY > 100 or absX > 120 then
                        return current
                    end

                    if not bestFallback then
                        bestFallback = current
                    end
                elseif current:IsA("GuiObject") and not bestFallback then
                    bestFallback = current
                end
            end

            current = current.Parent
        end

        return bestFallback
    end

    local function getVisibleEventCards()
        local visibleCards = {}
        local alreadyAdded = {}
        local scannedContainers = {}

        pcall(function()
            for _, gui in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
                if gui:IsA("TextLabel") and isGuiActuallyVisible(gui) then
                    local container = gui.Parent

                    if container and not scannedContainers[container] then
                        scannedContainers[container] = true

                        local cardName = extractKnownCardNameFromInstance(container)
                        if cardName and not alreadyAdded[cardName] then
                            local clickTarget = getClickableCardRoot(gui)

                            if not clickTarget then
                                clickTarget = getClickableCardRoot(container)
                            end

                            if clickTarget then
                                table.insert(visibleCards, {
                                    Name = cardName,
                                    Slot = #visibleCards + 1,
                                    UI = clickTarget
                                })
                                alreadyAdded[cardName] = true
                            end
                        end
                    end
                end
            end
        end)

        if #visibleCards > 3 then
            table.sort(visibleCards, function(a, b)
                local ay = math.huge
                local by = math.huge

                pcall(function()
                    ay = a.UI.AbsolutePosition.Y
                end)

                pcall(function()
                    by = b.UI.AbsolutePosition.Y
                end)

                return ay < by
            end)

            local trimmed = {}
            for i = 1, 3 do
                if visibleCards[i] then
                    visibleCards[i].Slot = i
                    table.insert(trimmed, visibleCards[i])
                end
            end
            visibleCards = trimmed
        end

        return visibleCards
    end


    local PLACE_COOLDOWN = 0.75
    local FARM_COOLDOWN = 0.75
    local UPGRADE_BURST_COOLDOWN = 0.4
    local FAIL_BACKOFF_BASE = 0.5
    local FAIL_BACKOFF_MAX = 2.0

    local function getFailBackoff()
        return math.min(FAIL_BACKOFF_BASE + (placementFailStreak * 0.25), FAIL_BACKOFF_MAX)
    end

    local function canDoGlobalAction()
        return (tick() - lastAutoActionAt) >= GLOBAL_ACTION_COOLDOWN
    end

    local function markGlobalAction()
        lastAutoActionAt = tick()
    end

    local function canAttemptFarm()
        return (tick() - lastFarmAttemptAt) >= FARM_COOLDOWN and canDoGlobalAction()
    end

    local function canAttemptPlacement()
        return (tick() - lastPlaceAttemptAt) >= (PLACE_COOLDOWN + getFailBackoff()) and canDoGlobalAction()
    end

    local function canBurstUpgrade()
        return (tick() - lastUpgradeBurstAt) >= UPGRADE_BURST_COOLDOWN and canDoGlobalAction()
    end

    local function markFarmAttempt(success)
        lastFarmAttemptAt = tick()
        markGlobalAction()
        if success then
            placementFailStreak = 0
        else
            placementFailStreak += 1
        end
    end

    local function markPlacementAttempt(success)
        lastPlaceAttemptAt = tick()
        markGlobalAction()
        if success then
            placementFailStreak = 0
        else
            placementFailStreak += 1
        end
    end

    local function markUpgradeBurst()
        lastUpgradeBurstAt = tick()
        markGlobalAction()
    end



    local function softResync()

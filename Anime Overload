    local function trySelectCardByRemote(targetCard)
        if not targetCard or not targetCard.Name then
            return false
        end

        local success = false

        pcall(function()
            local gamemodes = ReplicatedStorage:FindFirstChild("gamemodes")
            local gamemodesReliable = gamemodes and gamemodes:FindFirstChild("gamemodes_RELIABLE")
            if not gamemodesReliable then
                return
            end

            local cardName = tostring(targetCard.Name)
            if cardName == "" then
                return
            end

            -- optional hardening
            if #cardName > 255 then
                warn("[SmartCard] Card name too long for 1-byte payload length:", cardName)
                return
            end

            local payloadStr =
                string.char(0) ..
                string.char(2) ..
                string.char(#cardName) ..
                string.char(0) ..
                cardName

            gamemodesReliable:FireServer(buffer.fromstring(payloadStr), {})


            success = true
        end)

        return success
    end

    local function executeSmartCardSelect()
        if tick() - lastCardSelectAt < 4 then
            return false
        end

        if not isPickCardUIVisible() then
            return false
        end

        local ok, result = pcall(function()
            local visibleCards = getVisibleEventCards()
            if not visibleCards or #visibleCards == 0 then
                return false
            end

            local maxScore = -1
            local bestCards = {}

            for _, cardData in ipairs(visibleCards) do
                local score = MoMoConfig.CardPriorities[cardData.Name] or 1

                if score > maxScore then
                    maxScore = score
                    bestCards = {cardData}
                elseif score == maxScore then
                    table.insert(bestCards, cardData)
                end
            end

            if #bestCards == 0 then
                return false
            end

            local targetCard = bestCards[math.random(1, #bestCards)]
            local selected = trySelectCardByRemote(targetCard)

            if not selected then
                selected = clickGuiObject(targetCard.UI)
            end

            if not selected then
                return false
            end

            task.wait(0.35)

            local lockButton = findLockInChoiceButton()
            if lockButton then
                clickGuiObject(lockButton)
            end

            lastCardSelectAt = tick()
            return true
        end)

        if not ok then
            return false
        end

        return result == true
    end

    local function shouldPlaceMoreAttack(attackTowersBySlot)
        local totalAttack = 0
        local activeSlots = 0

        for slot = 1, 6 do
            local towers = attackTowersBySlot[slot]
            local count = towers and #towers or 0
            totalAttack += count
            if count > 0 then
                activeSlots += 1
            end
        end

        -- ยังไม่มีตัวตีเลย ต้องวาง
        if totalAttack == 0 then
            return true
        end

        -- ช่วงเปิดเกม: มีตัวตีน้อยเกินไป ให้ตั้งฐานก่อน
        if totalAttack < 2 then
            return true
        end

        -- ถ้ามีชนิดตัวตีน้อยมาก แต่อยากให้กระจายแนวอีกนิด
        if activeSlots < 2 and totalAttack < 4 then
            return true
        end

        -- ถ้าแนวรับเริ่มนิ่งแล้ว วางเพิ่มเฉพาะตอนมอนหลุดแนวจริงๆ
        return isDefenseBreached()
    end


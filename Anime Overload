    local recentFailedSpots = {}

    local function trimFailedSpots()
        local now = tick()
        local kept = {}
        for _, item in ipairs(recentFailedSpots) do
            if now - item.t < 8 then
                table.insert(kept, item)
            end
        end
        recentFailedSpots = kept
    end

    local function markFailedSpot(pos)
        if pos then
            table.insert(recentFailedSpots, {pos = pos, t = tick()})
        end
    end

    local function isNearFailedSpot(pos, radius)
        radius = radius or 4
        trimFailedSpots()
        for _, item in ipairs(recentFailedSpots) do
            if (item.pos - pos).Magnitude <= radius then
                return true
            end
        end
        return false
    end


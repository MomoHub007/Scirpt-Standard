            freshReliable:FireServer(buffer.fromstring("\001\a\001"), {})
            task.wait(2)
            freshReliable:FireServer(buffer.fromstring("\005\004"), {})

            return true
        end)

        if not ok then
            lastJoinAttempt = 0
            return false
        end

        return result == true
    end



    -- 🎬 3. เครื่องเล่นเทป (Macro Playback Engine) The Relentless Loop
    -- =====================================================================
    task.spawn(function()
        local HttpService = game:GetService("HttpService")
        local MacroFolder = "MoMoHub_Macros"
        local sync = nil
        local towersNet = nil

        while true do
            task.wait(0.5)
            
            if MoMoConfig.PlayMacro then
                
                -- โหลด Network Modules สดๆ
                if not sync then pcall(function() sync = require(ReplicatedStorage.gameClient.net.sync) end) end
                if not towersNet then pcall(function() towersNet = require(ReplicatedStorage.gameClient.net.towers) end) end

                -- Lazy-Load ไฟล์ Macro (ดึงข้อมูลล่าสุด)
                if (not _G.MoMoMacroLedger or #_G.MoMoMacroLedger == 0) and _G.SelectedMacro and _G.SelectedMacro ~= "None" then
                    local filepath = MacroFolder .. "/" .. _G.SelectedMacro .. ".json"
                    if isfile and isfile(filepath) and readfile then
                        local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(filepath)) end)
                        if success and type(decoded) == "table" and #decoded > 0 then
                            _G.MoMoMacroLedger = {}
                            for _, step in ipairs(decoded) do
                                -- รองรับไฟล์เก่า (RequiredMoney) และไฟล์ใหม่ (Cost)
                                local stepCost = step.Cost or step.RequiredMoney or 0
                                table.insert(_G.MoMoMacroLedger, {
                                    Action = step.Action, Slot = step.Slot, Cost = stepCost,
                                    CFrame = step.CFrameData and deserializeCFrame(step.CFrameData) or nil
                                })
                            end
                            _G.MacroCurrentStep = 1
                            print("✅ [Macro Playback] โหลดไฟล์: " .. _G.SelectedMacro)
                        end
                    end
                end

                -- เข้าลูปเล่น Macro (Relentless Execution)
                if _G.MoMoMacroLedger and #_G.MoMoMacroLedger > 0 and sync and towersNet then
                    if not _G.MacroCurrentStep then _G.MacroCurrentStep = 1 end
                    
                    if _G.MacroCurrentStep <= #_G.MoMoMacroLedger then
                        local stepData = _G.MoMoMacroLedger[_G.MacroCurrentStep]
                        local currentMoney = getRealMoney()
                        
                        -- รอจนกว่าเงินจะพอ
                        if currentMoney >= stepData.Cost then
                            local stepCompleted = false
                            local retryCount = 0
                            
                            -- 🛡️ ลูปกัดไม่ปล่อย: ทำจนกว่าเงินจะลด!
                            while not stepCompleted and MoMoConfig.PlayMacro do
                                local moneyBeforeAction = getRealMoney()
                                
                                if stepData.Action == "Place" then
                                    local deck = getDeckUUIDs()
                                    local targetUuid = nil
                                    if type(deck) == "table" then
                                        for _, c in pairs(deck) do
                                            if c.Slot == stepData.Slot then targetUuid = c.UUID break end
                                        end
                                    end
                                    if targetUuid then
                                        pcall(function() sync.clientTowerPlacement.call(targetUuid, stepData.CFrame) end)
                                    end
                                    
                                elseif stepData.Action == "Upgrade" then
                                    local placedFolder = workspace:FindFirstChild("placedTowers")
                                    local closestTower = nil
                                    local closestDist = 5
                                    
                                    if placedFolder then
                                        for _, obj in pairs(placedFolder:GetChildren()) do
                                            if obj:IsA("Model") and obj.Name:match("^tower%-") then
                                                local dist = (obj:GetPivot().Position - stepData.CFrame.Position).Magnitude
                                                if dist < closestDist then
                                                    closestDist = dist
                                                    closestTower = obj
                                                end
                                            end
                                        end
                                    end
                                    
                                    if closestTower then
                                        pcall(function() towersNet.upgradeUnit.call(closestTower.Name) end)
                                    end
                                end
                                
                                -- ⏳ รอเช็คบิล (ตรวจสอบว่าเงินลดลงไหมใน 1.5 วินาที)
                                local waitCheck = 0
                                while waitCheck < 1.5 and MoMoConfig.PlayMacro do
                                    task.wait(0.25)
                                    waitCheck = waitCheck + 0.25
                                    if getRealMoney() < moneyBeforeAction then
                                        stepCompleted = true
                                        break
                                    end
                                end
                                
                                if not stepCompleted then
                                    retryCount = retryCount + 1
                                    warn(string.format("⚠️ เงินยังไม่ลด! ย้ำคำสั่งรอบ %d (Step %d)", retryCount, _G.MacroCurrentStep))
                                end
                            end
                            
                            -- ทำสำเร็จแล้วเลื่อนไป Step ถัดไป
                            if stepCompleted then
                                print(string.format("✅ Step %d สำเร็จ! (%s)", _G.MacroCurrentStep, stepData.Action))
                                _G.MacroCurrentStep = _G.MacroCurrentStep + 1
                                task.wait(0.5) -- หน่วงก่อนไปสเตปต่อไป
                            end
                        end
                    else
                        MoMoNotify({Title = "Macro Finished", Desc = "✅ รัน Macro จบแล้วจ้า!", Time = 5})
                        MoMoConfig.PlayMacro = false
                        task.wait(2)
                    end
                end
            end
        end
    end)





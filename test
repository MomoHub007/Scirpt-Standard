local function StartLobbyMaster()
    local hud = LocalPlayer.PlayerGui:WaitForChild("HUD")
    local Tutorial = {}

    local function AttemptJoinPortals()
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not (char and hrp) then return false end

        -- 🎯 รายชื่อพิกัดทางเข้าด่านทั้งหมด
        local portalCoords = {
            Vector3.new(2723, -115, -1990),
            Vector3.new(2723, -115, -2019),
            Vector3.new(2723, -115, -2049),
            Vector3.new(2723, -115, -2079),
            Vector3.new(2723, -115, -2108)
        }

        _G.MoMoStatus("กำลังหาทางเข้าด่าน...")

        -- 🎯 ใช้ตัวแปร i เพื่อคอยนับว่าตอนนี้อยู่จุดที่เท่าไหร่
        local i = 1 
        
        while _G.LobbyActive do
            -- เช็คตัวละครอีกรอบเผื่อตายหรือบั๊กระหว่างรอ
            char = LocalPlayer.Character
            hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then task.wait(1); continue end

            local targetPos = portalCoords[i]
            print(string.format("🚀 [AttemptJoinPortals] ลองวาร์ปไปจุดที่ %d: %s", i, tostring(targetPos)))
            
            -- ✅ Step 1: วาร์ป HRP ไปพิกัดที่กำหนด
            hrp.CFrame = CFrame.new(targetPos)
            task.wait(1.5)  -- รอให้ตัวละครลงพื้นและโหลด

            -- ✅ Step 2: เลือก Stage และกด Start ด้วย Remote
            pcall(function() inputRemote:FireServer("Script448Level", "-1", false) end)
            task.wait(1)
            pcall(function() inputRemote:FireServer("Script448Start") end)

            if _G.MoMoStatus then _G.MoMoStatus(string.format("ส่งคำสั่งเข้าด่าน %d... รอผล 7 วิ", i)) end

            -- ✅ Step 3: ดีเลย์ 7 วินาที รอให้เกมประมวลผลดึงเข้าด่าน
            task.wait(7)

            -- ✅ Step 4: เช็คสถานะตรงๆ เลยว่าเกมเตะเราออกจาก Lobby หรือยัง
            if _G.LobbyActive then
                print("⚠️ [AttemptJoinPortals] 7 วิผ่านไป ยังเข้าไม่ได้ -> เตรียมย้ายจุด...")
                
                -- เลื่อนไปพิกัดถัดไป ถ้าเกิน 5 ให้กลับไปเริ่ม 1 ใหม่
                i = i + 1
                if i > #portalCoords then
                    i = 1
                    print("🔄 [AttemptJoinPortals] ลองครบทุกประตูแล้ว -> วนกลับมาเริ่มจุดที่ 1 ใหม่!")
                end
            else
                print("✅ [AttemptJoinPortals] กำลังวาร์ปเข้าด่านสำเร็จ!")
                return true
            end
        end

        return false
    end


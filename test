-- 🏅 [Helper] ฟังก์ชันดึงเลเวลผู้เล่นแบบ Global
-- 🏅 [Helper] ฟังก์ชันดึงเลเวลผู้เล่นแบบครอบคลุม (ทะลวงหาทุกจุดของเกม)
local function GetPlayerLevel()
    -- 1. เช็คจาก leaderstats (ASTD และเกมส่วนใหญ่ใช้จุดนี้)
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if ls and ls:FindFirstChild("Level") then
        return tonumber(ls.Level.Value) or 0
    end
    
    -- 2. เช็คจาก Stats (เผื่อเกมอัปเดตย้ายโฟลเดอร์)
    local stats = LocalPlayer:FindFirstChild("Stats")
    if stats and stats:FindFirstChild("Level") then
        return tonumber(stats.Level.Value) or 0
    end

    -- 3. ไม้ตายก้นหีบ! สแกนจาก "ป้ายข้อความบนหัวตัวละคร" 
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Head") then
        for _, v in pairs(char.Head:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Text:find("Lv") or v.Text:find("Level")) then
                local num = v.Text:match("%d+")
                if num then return tonumber(num) end
            end
        end
    end

    return 0
end


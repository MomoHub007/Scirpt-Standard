-- 🔓 [BagHelper] ขยายกระเป๋าถ้าเต็ม 
-- ==========================================
local function EnsureBagHasSpace()
    local maxRetries = 3

    for attempt = 1, maxRetries do
        local current, max, reason = GetBagStatus()

        if reason ~= "OK" or not current or not max then
            warn("⚠️ [EnsureBag] ดึงสถานะกระเป๋าไม่ได้ รอ 1 วิ...")
            task.wait(1)
            continue
        end

        print(string.format("🎒 [EnsureBag] สถานะกระเป๋า: %d/%d (รอบ %d)", current, max, attempt))

        -- ✅ กระเป๋าว่าง → ไม่ต้องทำอะไร
        if current < max then
            if _G.MoMoStatus then _G.MoMoStatus(string.format("กระเป๋าว่าง (%d/%d) พร้อมสุ่ม!", current, max)) end
            return true
        end

        -- 🔴 กระเป๋าเต็ม → ต้องขยาย
        if _G.MoMoStatus then _G.MoMoStatus(string.format("กระเป๋าเต็ม (%d/%d)! เช็คเงิน...", current, max)) end

        -- 💎 1. เรียกใช้ฟังก์ชันเช็คเงิน (มันจะติดลูปอยู่ตรงนี้จนกว่า Gem จะ >= 150)
        EnsureGemBeforeUpgradeBag()

        -- 💎 2. พอหลุดลูปมาได้ แปลว่า Gem >= 150 แน่นอน ค่อยส่งคำสั่งอัปเกรด!
        print(string.format("🎒 [EnsureBag] Gem ครบแล้ว! ส่งคำสั่ง UpgradeInventory..."))
        if _G.MoMoStatus then _G.MoMoStatus("Gem ครบแล้ว กำลังกดขยายกระเป๋า...") end
        
        pcall(function()
            serverRemote:InvokeServer("UpgradeInventory")
        end)
        task.wait(1.5)

        -- เช็คว่า max เพิ่มขึ้นไหม
        local newCurrent, newMax, newReason = GetBagStatus()
        if newReason == "OK" and newMax and newMax > max then
            -- ✅ ขยายสำเร็จ
            print(string.format("✅ [EnsureBag] ขยายกระเป๋าสำเร็จ! %d/%d -> %d/%d", current, max, newCurrent, newMax))
            return true
        end

        -- ❌ ขยายไม่ได้ (อาจติดบั๊กของค้างใน Storage) → กดรับของก่อน แล้วลูปกลับไปทำใหม่
        print("⚠️ [EnsureBag] ขยายไม่ได้ -> กดรับของใน Storage เคลียร์บั๊ก...")
        ClaimAllStorageRewards()
        task.wait(1)
    end

    warn("❌ [EnsureBag] ขยายกระเป๋าไม่สำเร็จหลังลอง 3 รอบ")
    return false
end


local function ParseCurrencyAmount(rawText)
    rawText = tostring(rawText or ""):gsub(",", ""):gsub("%s+", "")
    local num = tonumber(rawText:match("%d+"))
    return num or 0
end

local function GetHudCurrencyAmount(currencyName)
    local ok, amount = pcall(function()
        local hud = LocalPlayer.PlayerGui:WaitForChild("HUD")
        local currencyList = hud:WaitForChild("BottomFrame"):WaitForChild("CurrencyList")
        local currencyFrame = currencyList:FindFirstChild(currencyName)
        local amountLabel = currencyFrame and currencyFrame:FindFirstChild("Amount")
        if not amountLabel then
            return 0
        end
        return ParseCurrencyAmount(amountLabel.Text)
    end)

    if ok then
        return tonumber(amount) or 0
    end
    return 0
end


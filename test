    -- 🌟 [Helper] ฟังก์ชันนับจำนวนตัวละคร 4 ดาวในกระเป๋า
    -- 🌟 [Helper] ฟังก์ชันนับจำนวนตัวละคร 4 ดาวในกระเป๋า (เวอร์ชันทะลวง UI)
    local function Count4StarUnits()
        Tutorial.ForceLoadInventoryUI()
        task.wait(1.5)

        local hud = LocalPlayer.PlayerGui:WaitForChild("HUD")
        local invV2 = hud:FindFirstChild("InventoryV2")
        local scroll = invV2 and invV2:FindFirstChildWhichIsA("ScrollingFrame", true)
        
        if not scroll then
            warn("❌ [Count4Star] หา Inventory Scroll ไม่เจอ")
            return 0
        end

        local count = 0
        for _, uiObj in pairs(scroll:GetChildren()) do
            if uiObj:IsA("GuiObject") then
                local is4Star = false
                pcall(function()
                    -- 🎯 1. เช็คจาก Attribute (ข้อมูลหลังบ้าน)
                    local starAttr = tonumber(uiObj:GetAttribute("Star")) 
                                  or tonumber(uiObj:GetAttribute("Stars")) 
                                  or tonumber(uiObj:GetAttribute("Rarity"))
                    if starAttr == 4 then is4Star = true end
                    
                    -- 🎯 2. สแกนหาจากหน้าตา UI (ป้ายข้อความรูปดาว)
                    if not is4Star then
                        for _, desc in pairs(uiObj:GetDescendants()) do
                            -- 2.1 เช็ค TextLabel ที่เขียนเลข "4" เป๊ะๆ (และต้องไม่ใช่ป้าย Level)
                            if desc:IsA("TextLabel") then
                                local txt = tostring(desc.Text):gsub("%s+", "") -- ตัดช่องว่าง
                                if txt == "4" and not desc.Name:lower():find("lvl") and not desc.Name:lower():find("level") then
                                    is4Star = true
                                    break
                                end
                                -- หรือเผื่อเกมเขียนว่า "4Star" หรือ "4*"
                                if txt == "4Star" or txt == "4*" then
                                    is4Star = true
                                    break
                                end
                            end
                            
                            -- 2.2 เช็คจาก Value ที่อาจจะซ่อนอยู่
                            if (desc.Name:lower():find("star") or desc.Name:lower():find("rarity")) 
                               and (desc:IsA("IntValue") or desc:IsA("NumberValue")) then
                                if desc.Value == 4 then is4Star = true; break end
                            end
                        end
                    end
                end)

                if is4Star then 
                    count = count + 1 
                end
            end
        end
        
        print("🔍 [Count4Star] สแกนกระเป๋าพบตัว 4 ดาวทั้งหมด: " .. count .. " ตัว")
        return count
    end


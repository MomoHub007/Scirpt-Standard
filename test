local function ClaimAllLobbyTasks()
    if not _G.LobbyActive then
        return
    end

    for _, taskName in ipairs(LOBBY_TASK_CLAIMS) do
        local ok, err = pcall(function()
            inputRemote:FireServer("ClaimTask", taskName)
        end)

        if ok then
            print(string.format("✅ [LobbyTask] Claim sent | %s", tostring(taskName)))
        else
            warn(string.format("❌ [LobbyTask] Claim failed | %s | %s", tostring(taskName), tostring(err)))
        end

        task.wait(0.2)
    end
end

local function ClaimAllLobbyRewards()
    -- 🛑 เช็คไฟแดง: ถ้ากำลังทำ Tutorial หรือ "กำลังจัดทีม" อยู่ ห้ามรับของขวัญเด็ดขาด!
    if _G.TutorialActive or _G.EquippingTeam then
        return
    end

    local now = os.clock()
    if (now - lobbyGiftState.LastClaimAttempt) < lobbyGiftState.ClaimCooldown then
        return
    end
    lobbyGiftState.LastClaimAttempt = now

    if not _G.LobbyActive then
        return
    end

    if _G.MoMoStatus then
        _G.MoMoStatus("อยู่ใน Lobby -> กำลังรับ Giftbox / Task...")
    end

    ClaimAllLobbyGiftboxes()
    task.wait(0.4)
    ClaimAllLobbyTasks()
end


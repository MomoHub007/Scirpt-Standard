-- 🎁 [GiftboxHelper] คลิกรับ Giftbox ผ่าน UI จริง (FIXED v2)
-- Bug Fix: รองรับชื่อปุ่ม "Gifts" / "GiftBox" / ทุกชื่อที่มีคำว่า "gift"
-- ==========================================
local function ClaimAllLobbyGiftboxes()
    if not _G.LobbyActive then return end
    if _G.GiftboxClaiming then return end
    _G.GiftboxClaiming = true

    local okMain, errMain = pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        local hud = LocalPlayer.PlayerGui:WaitForChild("HUD")

        -- ✅ clickGui: ตรวจ visibility ทุก ancestor ก่อนคลิก (เพิ่มระบบชดเชยระยะ Topbar)
        local function clickGui(obj, clicks)
            if not obj or not obj.Parent then return false end
            local cur = obj
            while cur and cur ~= hud.Parent do
                if cur:IsA("GuiObject") and not cur.Visible then
                    return false
                end
                cur = cur.Parent
            end
            if obj.AbsoluteSize.X < 1 or obj.AbsoluteSize.Y < 1 then return false end

            clicks = clicks or 1
            local ap = obj.AbsolutePosition
            local as = obj.AbsoluteSize
            
            -- 🎯 [จุดที่แก้ไข] ดึงค่าระยะขอบจอ (Topbar Inset) ของ Roblox
            local inset = game:GetService("GuiService"):GetGuiInset()
            
            local cx = math.floor(ap.X + as.X * 0.5)
            -- 🎯 [จุดที่แก้ไข] บวกระยะ inset.Y เข้าไป เพื่อดึงเป้าหมายเมาส์ลงมาให้ตรงปุ่มเป๊ะๆ
            local cy = math.floor(ap.Y + as.Y * 0.5) + inset.Y 

            for _ = 1, clicks do
                VIM:SendMouseMoveEvent(cx, cy, game)
                task.wait(0.05)
                VIM:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                task.wait(0.08)
                VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                task.wait(0.12)
            end
            return true
        end

        -- =====================================================================
        -- ✅ FIX: getGiftButton() — ค้นหาแบบ fuzzy แทนการ hardcode "GiftBox"
        --    1. ค้นใน RightButton ด้วยชื่อหรือ Text ที่มีคำว่า "gift"
        --    2. Fallback ค้นใน hud โดยตรง
        --    3. Safety check: ถ้าชื่อมีคำว่า "storage" → ข้ามทันที
        -- =====================================================================
        local function getGiftButton()
            -- เข้าถึง RightButton จาก HUD
            local rightButton = hud:FindFirstChild("RightButton")
            
            if rightButton then
                -- เจาะจงหาปุ่มที่ชื่อ GiftBox ตาม Path ที่คุณให้มาเป๊ะๆ
                local giftBtn = rightButton:FindFirstChild("GiftBox")
                
                if giftBtn then
                    print("🎯 [Giftbox] ล็อคเป้าตรงเป๊ะ! Path: " .. giftBtn:GetFullName())
                    return giftBtn
                end
            end

            warn("❌ [Giftbox] หา HUD.RightButton.GiftBox ไม่เจอ")
            return nil
        end

        -- =====================================================================
        -- ✅ FIX: hasGiftNotif() — ใช้ giftBtn ที่หาได้แล้ว ไม่เรียก getGiftButton() ซ้ำ
        -- =====================================================================
        local function hasGiftNotif(giftBtn)
            if not giftBtn then return false end
            local notif = giftBtn:FindFirstChild("Notif")
            if not notif then
                -- Fallback: หา child ใดๆ ที่ Visible และดูเหมือน notification dot
                for _, c in ipairs(giftBtn:GetChildren()) do
                    if c:IsA("GuiObject") and c.Visible and
                       (c.Name:lower():find("notif") or c.Name:lower():find("badge") or c.Name:lower():find("dot")) then
                        return true
                    end
                end
                return false
            end
            return notif.Visible
        end

        -- =====================================================================
        -- ✅ findAllAcceptButtons() — เฉพาะใน subtree ของ gift panel
        --    ถ้าหา gift panel ไม่เจอ ค่อย fallback ค้นใน hud ทั้งหมด
        --    แต่ต้องแน่ใจว่าไม่ใช่ปุ่มของ Storage
        -- =====================================================================
        -- ✅ อัปเกรดระบบค้นหาปุ่ม: ล็อคเป้า Path จริงจากสปาย (ปุ่มชื่อ Claim)
        local function findAllAcceptButtons()
            local results = {}
            
            -- 🎯 1. เจาะเข้าไปที่หน้าต่าง GiftBox โดยตรง
            local giftBoxFrame = hud:FindFirstChild("GiftBox")
            if not giftBoxFrame then return results end
            
            -- 🎯 2. สแกนหาปุ่มทั้งหมดที่อยู่ข้างในกล่องของขวัญ
            for _, v in ipairs(giftBoxFrame:GetDescendants()) do
                if v:IsA("TextButton") or v:IsA("ImageButton") then
                    
                    -- 🎯 3. ล็อคเป้าหมายเฉพาะปุ่มที่ชื่อว่า "Claim" ตามที่เราสแกนเจอ
                    if v.Name:lower() == "claim" then
                        
                        local visible = true
                        local cur = v
                        while cur and cur ~= game do
                            -- ถ้าปุ่มโดนซ่อน ให้มองข้ามไป (ป้องกันการไปกดโดนไฟล์ต้นแบบ Template ที่ซ่อนอยู่)
                            if cur:IsA("GuiObject") and not cur.Visible then
                                visible = false; break
                            elseif cur:IsA("ScreenGui") and not cur.Enabled then
                                visible = false; break
                            end
                            cur = cur.Parent
                        end

                        -- เช็คเพิ่มว่าปุ่มต้องอยู่ในหน้าจอจริงๆ (AbsolutePosition > 0)
                        if visible and v.AbsolutePosition.X > 0 and v.AbsoluteSize.X >= 10 then
                            table.insert(results, v)
                        end
                    end
                end
            end
            
            return results
        end

        -- =====================================================================
        -- ✅ Main Flow
        -- =====================================================================

        -- Step 0: หา gift button ครั้งแรก
        local giftBtn = getGiftButton()

        if not giftBtn then
            warn("❌ [Giftbox] หาปุ่ม Gift ไม่เจอ → ข้ามการรับ Giftbox รอบนี้")
            return
        end

        -- ❌ Safety check สุดท้าย: ถ้าปุ่มที่หาได้เป็น Storage → abort
        if giftBtn.Name:lower():find("storage") then
            warn("❌ [Giftbox] Wrong button! ปุ่มที่พบคือ Storage ไม่ใช่ Gift → abort")
            return
        end

        -- ตรวจว่ามี Notif ไหม
        if not hasGiftNotif(giftBtn) then
            print("ℹ️ [Giftbox] ไม่มี Notif บนปุ่ม Gift -> ข้าม")
            return
        end

        if _G.MoMoStatus then
            _G.MoMoStatus("พบ GiftBox มีของรับ -> กำลังเปิด...")
        end

        local maxRounds = 60
        for round = 1, maxRounds do

            giftBtn = getGiftButton()
            if not giftBtn then break end

            if not hasGiftNotif(giftBtn) then
                print(string.format("✅ [Giftbox] Round %d: Notif หาย -> รับเสร็จแล้ว!", round))
                -- ถ้าของหมดแล้ว แต่ปุ่ม ACCEPT ยังค้างบนจอ (หน้าต่างเปิดอยู่) ให้คลิก Gift เพื่อปิดหน้าต่าง
                if #findAllAcceptButtons(hud) > 0 then
                    clickGui(giftBtn, 1)
                end
                break
            end

            -- 🎯 Step 1: สแกนหาปุ่ม ACCEPT บนหน้าจอก่อนเลย
            local acceptBtns = findAllAcceptButtons(hud)

            -- 🎯 Step 2: ถ้าไม่เจอปุ่ม ACCEPT แสดงว่าหน้าต่างยังปิดอยู่ -> ค่อยกดไอคอน Gift เพื่อเปิด
            if #acceptBtns == 0 then
                print(string.format("🎁 [Giftbox] Round %d → คลิกเปิดหน้าต่าง Gift...", round))
                clickGui(giftBtn, 1)
                task.wait(1.5) -- รอหน้าต่างเด้งและโหลด UI
                acceptBtns = findAllAcceptButtons(hud) -- สแกนหาอีกรอบหลังเปิด
            end

            -- 🎯 Step 3: ไล่กดปุ่ม ACCEPT รัวๆ
            if #acceptBtns > 0 then
                print(string.format("✅ [Giftbox] Round %d พบ ACCEPT %d ปุ่ม", round, #acceptBtns))
                for i, btn in ipairs(acceptBtns) do
                    print(string.format("   🖱️ กำลังกด ACCEPT #%d", i))
                    clickGui(btn, 1)
                    task.wait(0.6) -- หน่วงเวลาจำลองคนกด
                end
                task.wait(1) -- รอให้ Server อัปเดตข้อมูลของเข้าตัว
            else
                warn(string.format("⚠️ [Giftbox] Round %d ยังคงหาปุ่ม ACCEPT ไม่เจอ", round))
                task.wait(1.0)
            end
        end

        if _G.MoMoStatus then _G.MoMoStatus("จบขั้นตอนรับ GiftBox") end
    end)

    _G.GiftboxClaiming = false
    if not okMain then
        warn("❌ [Giftbox] Runtime Error: " .. tostring(errMain))
    end
end


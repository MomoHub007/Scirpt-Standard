local function GetCurrentWave()
    local waveNumber = 0
    pcall(function()
        local hud = Players.LocalPlayer.PlayerGui:FindFirstChild("HUD")
        
        -- 🎯 เปลี่ยนเป้าหมายจาก WaveText ไปเป็น Wave ธรรมดา (อันนี้คือป้ายของจริงที่ขยับตามเวฟ)
        local waveLabel = hud and hud:FindFirstChild("Wave")
        
        if waveLabel and waveLabel:IsA("TextLabel") then
            local txt = waveLabel.Text:lower()
            
            -- สกัดเอาเฉพาะตัวเลขที่ตามหลังคำว่า wave (เช่น wave 1 -> 1)
            local num = txt:match("wave%s*(%d+)")
            
            if num then
                waveNumber = tonumber(num)
            end
        end
    end)
    return waveNumber
end


    -- 🎰 [Helper] ฟังก์ชันสุ่มหาตัวละคร
    function Tutorial.AutoSummonUntilFound()
        local maxAttempts = 50
        local attempts = 0
        
        while attempts < maxAttempts do
            if HasTargetUnitInInventory() then
                print("✅ [AutoSummon] พบยูนิตเป้าหมายแล้ว!")
                return true
            end

            -- 🎯 1. เช็ค Stardust (ถ้าไม่พอมันจะเช็คจุดแดงที่กล่องของขวัญ)
            if not EnsureStardustBeforeSummon() then
                print("⚠️ [AutoSummon] Stardust ไม่พอและไม่มีของขวัญ -> เปิดโหมด Fallback 4 ดาว!")
                _G.Fallback4StarMode = true
                
                -- 🚨 ดักจับเลเวล 10 ทันทีที่รู้ว่าของหมด!
                if GetPlayerLevel() >= 10 then
                    print("🚨 [Fallback] เลเวล 10+ แล้ว! ทำการใส่โค้ด รับแคปซูล และรีจอยทันที!")
                    if _G.MoMoStatus then _G.MoMoStatus("LV.10+ รับรางวัล & รีจอย...") end
                    pcall(function() serverRemote:InvokeServer("Code", "bigcode3") end)
                    task.wait(1.5)
                    pcall(function() serverRemote:InvokeServer("Consume", "Reward Capsule", nil, 1) end)
                    pcall(function() serverRemote:InvokeServer("Consume", "Reward Capsule", 1) end)
                    task.wait(1.5)
                    Tutorial.Rejoin()
                    task.wait(999) -- แช่แข็งรอเกมเตะ
                end
                
                return true -- ส่งไม้ต่อให้ระบบใส่ 4 ดาว
            end

            -- 🎒 เช็คกระเป๋า
            if not EnsureBagHasSpace() then task.wait(3); continue end

            attempts = attempts + 1
            if _G.MoMoStatus then _G.MoMoStatus("กำลังกดสุ่มหาตัว Target (รอบที่ " .. attempts .. ")...") end
            pcall(function() serverRemote:InvokeServer("BannerSummon", 10, "Rerun101") end)
            task.wait(4)
        end
        return false
    end

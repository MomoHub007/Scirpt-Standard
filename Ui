local cfgSection = SettingsTab:Section({ Title = "💾 Config Manager", Box = true, BoxBorder = true, Opened = true })

local cfgMgr = Window.ConfigManager
local cfgName = "Default"

-- Input ชื่อ Config
local cfgInput = cfgSection:Input({
    Flag = "CfgName",
    Title = "Config Name",
    Value = "Default",
    Placeholder = "กรอกชื่อ config...",
    Callback = function(n)
        cfgName = (n ~= "" and n or "Default")
    end,
})

-- Dropdown รายชื่อ Config ทั้งหมด
local cfgList = cfgSection:Dropdown({
    Flag = "CfgList",
    Title = "📂 Saved Configs",
    Values = cfgMgr:AllConfigs(),
    Value = nil,
    Callback = function(n)
        if n then
            cfgName = n
            cfgInput:Set(n)
        end
    end,
})

cfgSection:Space()

-- ✅ Auto Load Config Toggle
cfgSection:Toggle({
    Flag    = "AutoLoadCfg",
    Title   = "⚡ Auto Load Config on Start",
    Desc    = "โหลด config อัตโนมัติเมื่อเปิดสคริปต์",
    Value   = false,
    Callback = function(v)
        getgenv().MoMoHub.AutoLoad = v
        WindUI:Notify({
            Title   = v and "Auto Load ON" or "Auto Load OFF",
            Content = v and ("จะโหลด [" .. cfgName .. "] อัตโนมัติ") or "ปิดการโหลดอัตโนมัติแล้ว",
            Duration = 3,
        })

        -- ถ้าเปิด Auto Load ให้บันทึก flag ลง config ปัจจุบันด้วย
        if v then
            local cfg = cfgMgr:Config(cfgName)
            cfg:Save()
        end
    end,
})

cfgSection:Space()

-- กลุ่มปุ่ม Save / Load
local cfgActionGroup = cfgSection:Group({})

cfgActionGroup:Button({
    Title = "💾 Save Config",
    Icon  = "save",
    Color = Green,
    Justify = "Center",
    Callback = function()
        if cfgName == "" then
            WindUI:Notify({ Title = "⚠️ Error", Content = "กรุณาใส่ชื่อ config ก่อน", Duration = 3 })
            return
        end
        local cfg = cfgMgr:Config(cfgName)
        if cfg:Save() then
            WindUI:Notify({ Title = "✅ Saved!", Content = "บันทึก [" .. cfgName .. "] สำเร็จ", Duration = 3 })
            cfgList:Refresh(cfgMgr:AllConfigs()) -- Refresh list หลัง Save
        end
    end,
})

cfgActionGroup:Space()

cfgActionGroup:Button({
    Title = "📂 Load Config",
    Icon  = "download",
    Color = Blue,
    Justify = "Center",
    Callback = function()
        if cfgName == "" then
            WindUI:Notify({ Title = "⚠️ Error", Content = "กรุณาเลือก config ก่อน", Duration = 3 })
            return
        end
        local cfg = cfgMgr:CreateConfig(cfgName)
        if cfg:Load() then
            WindUI:Notify({ Title = "✅ Loaded!", Content = "โหลด [" .. cfgName .. "] สำเร็จ", Duration = 3 })
        else
            WindUI:Notify({ Title = "❌ Failed", Content = "ไม่พบ config: " .. cfgName, Duration = 3 })
        end
    end,
})

cfgSection:Space()

-- กลุ่มปุ่ม Delete / Refresh
local cfgManageGroup = cfgSection:Group({})

cfgManageGroup:Button({
    Title = "🗑️ Delete Config",
    Icon  = "trash-2",
    Color = Red,
    Justify = "Center",
    Callback = function()
        if cfgName == "" or cfgName == "Default" then
            WindUI:Notify({ Title = "⚠️ Error", Content = "ไม่สามารถลบ Default config ได้", Duration = 3 })
            return
        end
        local cfg = cfgMgr:Config(cfgName)
        if cfg:Delete() then
            WindUI:Notify({ Title = "🗑️ Deleted", Content = "ลบ [" .. cfgName .. "] สำเร็จ", Duration = 3 })
            cfgName = "Default"
            cfgInput:Set("Default")
            cfgList:Refresh(cfgMgr:AllConfigs()) -- Refresh list หลัง Delete
        else
            WindUI:Notify({ Title = "❌ Failed", Content = "ไม่พบ config นี้", Duration = 3 })
        end
    end,
})

cfgManageGroup:Space()

cfgManageGroup:Button({
    Title = "🔄 Refresh List",
    Icon  = "refresh-cw",
    Color = Yellow,
    Justify = "Center",
    Callback = function()
        local configs = cfgMgr:AllConfigs()
        cfgList:Refresh(configs)
        WindUI:Notify({
            Title   = "🔄 Refreshed!",
            Content = "พบ " .. #configs .. " config",
            Duration = 3,
        })
    end,
})

